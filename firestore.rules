rules_version = '2';

// Reglas de seguridad de Firestore para la app Hogar.
// Despliega con:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null;
    }

    // hogarId del usuario que hace la petición.
    function miHogar() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.hogarId;
    }

    // ¿Es el usuario miembro de este hogar?
    function esMiembro(hogarId) {
      return autenticado() &&
        request.auth.uid in get(/databases/$(database)/documents/hogares/$(hogarId)).data.miembros;
    }

    // ───────── Usuarios ─────────
    match /usuarios/{uid} {
      // Lee su propio doc o el de un compañero del mismo hogar.
      allow read: if autenticado() && (uid == request.auth.uid || resource.data.hogarId == miHogar());
      // Solo puede crear/editar su propio documento.
      allow create, update: if autenticado() && uid == request.auth.uid;
      allow delete: if false;
    }

    // ───────── Hogares ─────────
    match /hogares/{hogarId} {
      // Lectura abierta a usuarios autenticados (necesario para buscar por código al unirse).
      allow read: if autenticado();
      // Crear: el creador debe estar en la lista de miembros.
      allow create: if autenticado() && request.auth.uid in request.resource.data.miembros;
      // Actualizar: ya es miembro, o se está añadiendo a sí mismo (unirse).
      allow update: if autenticado() &&
        (request.auth.uid in resource.data.miembros ||
         request.auth.uid in request.resource.data.miembros);
      allow delete: if false;

      // ───────── Subcolecciones del hogar ─────────
      match /{coleccion}/{docId} {
        allow read, write: if esMiembro(hogarId);

        // Items de las listas (un nivel más profundo).
        match /{sub=**} {
          allow read, write: if esMiembro(hogarId);
        }
      }
    }
  }
}
