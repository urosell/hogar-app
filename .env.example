# ─────────────────────────────────────────────────────────────
# Configuración de Firebase
# Copia este archivo a ".env" y rellena con los valores reales de
# tu proyecto (Consola Firebase → Configuración del proyecto → Tus apps).
# ─────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Clave VAPID para notificaciones push (Firebase Cloud Messaging)
# Consola Firebase → Configuración → Cloud Messaging → Certificados push web
VITE_FIREBASE_VAPID_KEY=

# Base path para GitHub Pages. Para un repo "hogar-app" => /hogar-app/
# (solo se usa en build de producción; en local siempre es "/")
VITE_BASE_PATH=/hogar-app/
